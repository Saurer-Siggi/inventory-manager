# Shared access password — everyone who knows it can use the app.
APP_PASSWORD=change-me

# Secret used to sign the session cookie. Use a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# Path to the SQLite database file. Defaults to data/inventory.db when unset.
# In Docker this points at the mounted volume (see docker-compose.yml).
DATABASE_PATH=data/inventory.db

# Public origin of the deployed app. Required in production behind a reverse proxy
# (TLS termination) so SvelteKit's CSRF check accepts the login/logout form POSTs.
# Leave unset for local `npm run dev`.
# ORIGIN=https://inventory.example.com
