# Supabase Configuration
PUBLIC_SUPABASE_URL=https://dummy.supabase.co
PUBLIC_SUPABASE_ANON_KEY=dummy_key_for_build

# Example:
# PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Comma-separated emails that may use /admin, /locations (storage + stock count), and edit alert rules on /alerts.
# If unset or empty, no account is treated as admin.
# ADMIN_EMAILS=you@example.com,other@example.com